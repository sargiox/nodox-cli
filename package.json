{
  "name": "nodox-cli",
  "version": "1.0.5",
  "description": "Instant interactive API documentation for Express — zero config, zero annotations",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    },
    "./jest-setup": {
      "types": "./jest-setup.d.ts",
      "import": "./src/layer4/jest-setup.js",
      "require": "./dist/jest-setup.cjs"
    }
  },
  "bin": {
    "nodox": "src/cli/nodox.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src",
    "ui/dist",
    "dist",
    "index.d.ts",
    "jest-setup.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:ui": "vite build",
    "build:cjs": "node scripts/build-cjs.js",
    "build": "npm run build:ui && npm run build:cjs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "express",
    "api",
    "documentation",
    "swagger",
    "openapi",
    "developer-tools"
  ],
  "author": "Dhruv Bhalodia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhruv-bhalodia/nodox-cli.git"
  },
  "homepage": "https://github.com/dhruv-bhalodia/nodox-cli#readme",
  "bugs": {
    "url": "https://github.com/dhruv-bhalodia/nodox/issues"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "@xyflow/react": "^12.10.2",
    "esbuild": "^0.25.12",
    "express": "^4.21.2",
    "jest": "^29.7.0",
    "joi": "^18.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "supertest": "^7.2.2",
    "vite": "^6.4.1",
    "zod": "^4.3.6"
  }
}
